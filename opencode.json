{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-hooks-plugin"
  ],
  "default_agent": "zeus",
  "command": {},
  "mcp": {
    "opencode-docs": {
      "type": "remote",
      "url": "https://tryinspector.com/api/opencode-docs/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 8000
  },
  "provider": {
    "opencode": {
      "options": {
        "chunkTimeout": 120000
      }
    },
    "github-copilot": {}
  },
  "permission": {
    "websearch": "allow",
    "bash": {
      "rm -rf /": "deny",
      "sudo rm *": "deny",
      "dd *": "deny",
      "> /dev/*": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "chmod *": "ask",
      "sudo *": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "black *": "allow",
      "pip *": "allow",
      "docker *": "allow",
      "curl *": "allow",
      "gh *": "allow",
      "make *": "allow"
    },
    "skill": {
      "*": "allow"
    }
  },
  "instructions": [
    "AGENTS.md",
    "instructions/*.instructions.md"
  ]
}
