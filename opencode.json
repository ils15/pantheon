{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-hooks-plugin"],
  "default_agent": "zeus",
  "mcp": {
    "opencode-docs": {
      "type": "remote",
      "url": "https://tryinspector.com/api/opencode-docs/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    }
  },
  "agent": {
    "zeus": {
      "description": "Central orchestrator — delegates to specialized agents, never implements directly",
      "color": "#FFD700",
      "temperature": 0.2,
      "steps": 30,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "*": "allow"
        }
      },
      "mode": "primary",
      "task_budget": 30
    },
    "athena": {
      "description": "Strategic planner — creates TDD-driven implementation plans with research-first architecture approach",
      "color": "#FFD700",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "mode": "primary",
      "task_budget": 10
    },
    "themis": {
      "description": "Quality & security gate — MANDATORY review after every implementation phase",
      "color": "#FFD700",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "ask",
        "bash": {
          "pytest *": "allow",
          "ruff *": "allow",
          "grep *": "allow",
          "npx vitest *": "allow",
          "pip *": "allow"
        }
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 5
    },
    "hermes": {
      "description": "Backend specialist — FastAPI, Python, async/await, TDD red-green-refactor",
      "color": "#4A90D9",
      "temperature": 0.3,
      "steps": 30,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 5,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "aphrodite": {
      "description": "Frontend specialist — React 19, TypeScript strict, WCAG accessibility, TDD",
      "color": "#4A90D9",
      "temperature": 0.5,
      "steps": 30,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 5,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "demeter": {
      "description": "Database specialist — SQLAlchemy 2.0, Alembic, query optimization, N+1 prevention",
      "color": "#4A90D9",
      "temperature": 0.2,
      "steps": 20,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 5,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "prometheus": {
      "description": "Infrastructure specialist — Docker multi-stage builds, docker-compose, CI/CD",
      "color": "#4A90D9",
      "temperature": 0.2,
      "steps": 15,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "hephaestus": {
      "description": "AI pipelines specialist — RAG, LangChain/LangGraph, vector stores, embeddings",
      "color": "#4A90D9",
      "temperature": 0.3,
      "steps": 25,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 5,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "chiron": {
      "description": "Model provider hub — multi-model routing, AWS Bedrock, cost optimization",
      "color": "#4A90D9",
      "temperature": 0.2,
      "steps": 20,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "echo": {
      "description": "Conversational AI specialist — Rasa NLU, dialogue management, intent/entity design",
      "color": "#4A90D9",
      "temperature": 0.4,
      "steps": 20,
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "gaia": {
      "description": "Remote sensing domain specialist — satellite image processing, spectral analysis, SAR, change detection. Read-only analysis of geospatial data.",
      "color": "#4A90D9",
      "temperature": 0.2,
      "steps": 20,
      "disable_model_invocation": true,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3
    },
    "apollo": {
      "description": "Investigation scout — 3-10 parallel codebase searches, read-only, no edits",
      "color": "#50C878",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 0
    },
    "iris": {
      "description": "GitHub operations — branches, pull requests, issues, releases, tags",
      "color": "#50C878",
      "temperature": 0.2,
      "steps": 12,
      "permission": {
        "edit": "deny",
        "bash": {
          "git *": "allow",
          "gh *": "allow"
        }
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 2
    },
    "mnemosyne": {
      "description": "Memory bank management — ADRs, project.md, atomic facts to /memories/repo/",
      "color": "#50C878",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "allow",
        "bash": "deny"
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 0
    },
    "talos": {
      "description": "Hotfix express lane — small bugs, CSS, typos, direct fixes, no TDD ceremony",
      "color": "#50C878",
      "temperature": 0.3,
      "steps": 5,
      "disable_model_invocation": true,
      "permission": {
        "edit": "allow",
        "bash": {
          "git add *": "allow",
          "npx prettier *": "allow",
          "git *": "allow"
        }
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 0
    },
    "nyx": {
      "description": "Observability specialist — OpenTelemetry, LangSmith, token/cost tracking, alerting",
      "color": "#50C878",
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "ask",
        "bash": "allow"
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3
    },
    "argus": {
      "description": "Visual analysis specialist — interprets screenshots, images, PDFs, diagrams, and UI mockups",
      "color": "#50C878",
      "temperature": 0.2,
      "steps": 15,
      "disable_model_invocation": true,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 0
    },
    "agora": {
      "description": "Multi-perspective synthesis engine — analyzes questions from multiple domain perspectives internally, compares agreements & divergences, produces decisive recommendation with confidence level.",
      "color": "#9B59B6",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "mnemosyne": "allow"
        }
      },
      "mode": "subagent",
      "hidden": true,
      "task_budget": 3
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 8000
  },
  "provider": {
    "opencode": {
      "options": {
        "chunkTimeout": 30000
      }
    },
    "github-copilot": {}
  },
  "permission": {
    "websearch": "allow",
    "bash": {
      "rm -rf /": "deny",
      "sudo rm *": "deny",
      "dd *": "deny",
      "> /dev/*": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "chmod *": "ask",
      "sudo *": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "black *": "allow",
      "pip *": "allow",
      "docker *": "allow",
      "curl *": "allow",
      "gh *": "allow",
      "make *": "allow"
    },
    "skill": {
      "*": "allow"
    }
  },
  "instructions": [
    "AGENTS.md",
    "instructions/*.instructions.md"
  ]
}
