{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "pantheon-tui-plugin"
  ],
  "default_agent": "zeus",
  "command": {},
  "mcp": {
    "pantheon-resources": {
      "type": "local",
      "cwd": ".",
      "command": [
        "python3",
        "scripts/mcp_resources_server.py"
      ],
      "enabled": true
    },
    "pantheon-code-mode": {
      "type": "local",
      "cwd": ".",
      "command": [
        "python3",
        "scripts/code_mode_server.py"
      ],
      "enabled": true
    },
    "pantheon-memory": {
      "type": "local",
      "cwd": ".",
      "command": [
        ".venv/bin/python3",
        "scripts/memory_mcp_server.py"
      ],
      "enabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 8000
  },
  "provider": {
    "opencode": {
      "options": {
        "chunkTimeout": 120000,
        "headerTimeout": 10000
      }
    },
    "github-copilot": {}
  },
  "permission": {
    "websearch": "allow",
    "bash": {
      "rm -rf /": "deny",
      "sudo rm *": "deny",
      "dd *": "deny",
      "> /dev/*": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "chmod *": "ask",
      "sudo *": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "black *": "allow",
      "pip *": "allow",
      "docker *": "allow",
      "curl *": "allow",
      "gh *": "allow",
      "make *": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "mcp": {
      "pantheon-resources": "allow",
      "pantheon-code-mode": "ask",
      "*": "ask",
      "pantheon-memory": "allow"
    }
  },
  "instructions": [
    "AGENTS.md",
    "instructions/*.instructions.md"
  ]
}