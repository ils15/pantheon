{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-hooks-plugin"
  ],
  "default_agent": "zeus",
  "command": {},
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 8000
  },
  "provider": {
    "opencode": {
      "options": {
        "chunkTimeout": 120000,
        "headerTimeout": 10000
      }
    },
    "github-copilot": {}
  },
  "permission": {
    "websearch": "allow",
    "bash": {
      "rm -rf /": "deny",
      "sudo rm *": "deny",
      "dd *": "deny",
      "> /dev/*": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "chmod *": "ask",
      "sudo *": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "black *": "allow",
      "pip *": "allow",
      "docker *": "allow",
      "curl *": "allow",
      "gh *": "allow",
      "make *": "allow"
    },
    "skill": {
      "*": "allow"
    }
  },
  "instructions": [
    "AGENTS.md",
    "instructions/*.instructions.md"
  ]
}