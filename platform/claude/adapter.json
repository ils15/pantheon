{
  "name": "claude",
  "displayName": "Claude Code",
  "version": "2.0.0",

  "description": "Claude Code uses .md files in .claude/agents/ with comma-separated tools string (not YAML arrays).",

  "outputDir": "agents",
  "fileExtension": ".md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "mode",
      "tools",
      "skills",
      "instructions"
    ],
    "exclude": [
      "handoffs",
      "agents",
      "disable-model-invocation",
      "model",
      "argument-hint",
      "user-invocable"
    ],
    "transform": {
      "tools": { "strategy": "comma-separated" },
      "skills": { "strategy": "comma-separated" },
      "instructions": { "strategy": "comma-separated" },
      "mode": { "strategy": "identity" }
    }
  },

  "toolMap": {
    "search/codebase": "Grep",
    "search/usages": "Grep",
    "search/fileSearch": "Glob",
    "search/textSearch": "Grep",
    "search/listDirectory": "Glob",
    "search/changes": "Bash",
    "read/readFile": "Read",
    "edit/editFiles": "Edit",
    "execute/runInTerminal": "Bash",
    "execute/testFailure": "Bash",
    "execute/getTerminalOutput": "Bash",
    "web/fetch": "WebFetch",
    "agent": "Agent",
    "vscode/askQuestions": "AskUserQuestion"
  },

  "excludeTools": [
    "read/problems",
    "execute/createAndRunTask",
    "vscode/runCommand",
    "browser/openBrowserPage",
    "browser/navigatePage",
    "browser/readPage",
    "browser/clickElement",
    "browser/typeInPage",
    "browser/hoverElement",
    "browser/dragElement",
    "browser/handleDialog",
    "browser/screenshotPage"
  ],

  "capabilityFlags": {
    "orchestration": true,
    "approval": true,
    "diagnostics": false,
    "browser-ui": false,
    "ide-local": false,
    "github-service": false
  },

  "bodyFilters": [
    {
      "pattern": "## Copilot Workflow Updates",
      "action": "omit-section"
    },
    {
      "pattern": "## Agent Lifecycle Hooks",
      "action": "omit-section"
    },
    {
      "pattern": "### VS Code 1.111-1.114",
      "action": "omit-section"
    },
    {
      "pattern": "### Changelog-aligned notes",
      "action": "omit-section"
    }
  ]
}
