{
  "name": "opencode",
  "displayName": "OpenCode",
  "version": "2.0.0",

  "description": "OpenCode uses .md files with YAML frontmatter. Strips VS Code-specific frontmatter fields and appends permission blocks.",

  "outputDir": "agents",
  "fileExtension": ".md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "mode",
      "tools",
      "skills",
      "instructions",
      "argument-hint"
    ],
    "exclude": [
      "handoffs",
      "agents",
      "disable-model-invocation"
    ],
    "transform": {
      "tools": { "strategy": "identity" },
      "mode": { "strategy": "identity" }
    }
  },

  "toolMap": {
    "search/codebase": "codesearch",
    "search/usages": "codesearch",
    "search/fileSearch": "glob",
    "search/textSearch": "grep",
    "search/listDirectory": "list",
    "search/changes": "bash",
    "read/readFile": "read",
    "edit/editFiles": "edit",
    "execute/runInTerminal": "bash",
    "execute/testFailure": "bash",
    "execute/getTerminalOutput": "bash",
    "web/fetch": "webfetch",
    "agent": "task"
  },

  "excludeTools": [
    "read/problems",
    "execute/createAndRunTask",
    "vscode/askQuestions",
    "vscode/runCommand",
    "browser/openBrowserPage",
    "browser/navigatePage",
    "browser/readPage",
    "browser/clickElement",
    "browser/typeInPage",
    "browser/hoverElement",
    "browser/dragElement",
    "browser/handleDialog",
    "browser/screenshotPage"
  ],

  "ensureAgentTool": true,

  "capabilityFlags": {
    "orchestration": true,
    "approval": false,
    "diagnostics": false,
    "browser-ui": false,
    "ide-local": false,
    "github-service": false
  },

  "bodyFilters": [
    {
      "pattern": "## Copilot Workflow Updates",
      "action": "omit-section"
    },
    {
      "pattern": "## Agent Lifecycle Hooks",
      "action": "omit-section"
    },
    {
      "pattern": "## VS Code Integration",
      "action": "omit-section"
    }
  ]
}
