{
  "name": "opencode",
  "displayName": "OpenCode",
  "version": "1.0.0",

  "description": "OpenCode uses .md files with YAML frontmatter. Strips VS Code-specific frontmatter fields and appends permission blocks.",

  "outputDir": "agents",
  "fileExtension": ".md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "model",
      "tools",
      "skills",
      "instructions",
      "argument-hint"
    ],
    "exclude": [
      "handoffs",
      "agents",
      "disable-model-invocation"
    ],
    "transform": {
      "tools": { "strategy": "identity" },
      "model": { "strategy": "omit" }
    }
  },

  "toolMap": {},

  "excludeTools": [
    "vscode/askQuestions",
    "vscode/runCommand",
    "execute/createAndRunTask",
    "browser/openBrowserPage",
    "browser/navigatePage",
    "browser/readPage",
    "browser/clickElement",
    "browser/typeInPage",
    "browser/hoverElement",
    "browser/dragElement",
    "browser/handleDialog",
    "browser/screenshotPage"
  ],

  "ensureAgentTool": true,

  "capabilityFlags": {
    "orchestration": true,
    "approval": false,
    "diagnostics": false,
    "browser-ui": false,
    "ide-local": false,
    "github-service": false
  },

  "bodyFilters": [
    {
      "action": "append",
      "content": "---\n\n## Permissions\n\n- `edit`: deny\n- `execute`: deny\n- `search`: allow\n- `read`: allow"
    }
  ]
}
