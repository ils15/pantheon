{
  "mcpServers": {
    "pantheon-resources": {
      "command": "python3",
      "args": ["scripts/mcp_resources_server.py"],
      "disabled": false,
      "autoApprove": []
    },
    "pantheon-code-mode": {
      "command": "python3",
      "args": ["scripts/code_mode_server.py"],
      "disabled": false,
      "autoApprove": []
    },
    "pantheon-memory": {
      "command": ".venv/bin/python3",
      "args": ["scripts/memory_mcp_server.py"],
      "disabled": false,
      "autoApprove": ["memory_store", "memory_search", "memory_recall"]
    },
    "pantheon-persistence": {
      "command": ".venv/bin/python3",
      "args": ["scripts/mcp_persistence_server.py"],
      "disabled": false,
      "autoApprove": []
    }
  }
}
