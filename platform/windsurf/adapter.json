{
  "name": "windsurf",
  "displayName": "Windsurf (Cascade)",
  "version": "2.0.0",

  "description": "Windsurf Cascade agents using .windsurf/agents/ format with YAML tools arrays and Cascade tool naming.",

  "outputDir": "agents",
  "fileExtension": ".md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "mode",
      "tools",
      "skills",
      "instructions"
    ],
    "exclude": [
      "model",
      "handoffs",
      "agents",
      "disable-model-invocation",
      "argument-hint",
      "user-invocable"
    ],
    "transform": {
      "tools": { "strategy": "identity" },
      "model": { "strategy": "omit" },
      "mode": { "strategy": "identity" }
    }
  },

  "toolMap": {
    "search/codebase": "search",
    "search/usages": "search",
    "search/fileSearch": "search",
    "search/textSearch": "search",
    "search/listDirectory": "search",
    "search/changes": "search",
    "read/readFile": "read",
    "edit/editFiles": "edit",
    "execute/runInTerminal": "runInTerminal",
    "execute/testFailure": "runInTerminal",
    "execute/getTerminalOutput": "runInTerminal",
    "web/fetch": "webFetch"
  },

  "excludeTools": [
    "agent",
    "read/problems",
    "execute/createAndRunTask",
    "vscode/askQuestions",
    "vscode/runCommand",
    "browser/openBrowserPage",
    "browser/navigatePage",
    "browser/readPage",
    "browser/clickElement",
    "browser/typeInPage",
    "browser/hoverElement",
    "browser/dragElement",
    "browser/handleDialog",
    "browser/screenshotPage"
  ],

  "capabilityFlags": {
    "orchestration": false,
    "approval": false,
    "diagnostics": false,
    "browser-ui": false,
    "ide-local": false,
    "github-service": false
  },

  "ensureAgentTool": false,

  "bodyFilters": [
    {
      "pattern": "## Copilot Workflow Updates",
      "action": "omit-section"
    }
  ]
}
