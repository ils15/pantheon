{
  "name": "windsurf",
  "displayName": "Windsurf (stub)",
  "version": "1.0.0",

  "description": "Windsurf platform stub — placeholder for future Windsurf Cascade integration.",

  "outputDir": "agents",
  "fileExtension": ".md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "tools"
    ],
    "exclude": [
      "model",
      "skills",
      "instructions",
      "handoffs",
      "agents",
      "disable-model-invocation",
      "argument-hint",
      "user-invocable"
    ],
    "transform": {
      "tools": { "strategy": "identity" },
      "model": { "strategy": "omit" }
    }
  },

  "toolMap": {
    "search/codebase": "search",
    "search/usages": "search",
    "search/fileSearch": "search",
    "search/textSearch": "search",
    "search/listDirectory": "search",
    "search/changes": "search",
    "read/readFile": "read",
    "edit/editFiles": "edit",
    "execute/runInTerminal": "runInTerminal",
    "execute/testFailure": "runInTerminal",
    "execute/getTerminalOutput": "runInTerminal",
    "web/fetch": "webFetch"
  },

  "excludeTools": [
    "agent",
    "read/problems",
    "execute/createAndRunTask",
    "vscode/askQuestions",
    "vscode/runCommand",
    "browser/openBrowserPage",
    "browser/navigatePage",
    "browser/readPage",
    "browser/clickElement",
    "browser/typeInPage",
    "browser/hoverElement",
    "browser/dragElement",
    "browser/handleDialog",
    "browser/screenshotPage"
  ],

  "capabilityFlags": {
    "orchestration": false,
    "approval": false,
    "diagnostics": false,
    "browser-ui": false,
    "ide-local": false,
    "github-service": false
  },

  "bodyFilters": [
    {
      "pattern": "## Copilot Workflow Updates",
      "action": "omit-section"
    }
  ]
}
