{
  "name": "vscode",
  "displayName": "VS Code Copilot",
  "version": "1.0.0",

  "description": "Identity adapter — canonical agents ARE VS Code .agent.md files",

  "strategy": "identity",
  "outputDir": "agents",
  "fileExtension": ".agent.md",

  "frontmatter": {
    "include": [
      "name",
      "description",
      "model",
      "tools",
      "skills",
      "instructions",
      "handoffs",
      "agents",
      "disable-model-invocation",
      "argument-hint",
      "user-invocable"
    ],
    "transform": {
      "tools": { "strategy": "identity" },
      "model": { "strategy": "identity" },
      "handoffs": { "strategy": "identity" }
    }
  },

  "toolMap": {},

  "bodyFilters": []
}
