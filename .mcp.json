{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "gh_grep": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/grep-mcp-server"
      ]
    },
    "pantheon-resources": {
      "command": "python",
      "args": [
        "scripts/mcp_resources_server.py"
      ]
    },
    "pantheon-memory": {
      "command": ".venv/bin/python3",
      "args": [
        "scripts/memory_mcp_server.py"
      ]
    }
  }
}