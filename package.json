{
  "name": "pantheon-orchestrator",
  "version": "1.0.3",
  "description": "Multi-agent orchestration platform with 14 specialized agents, 40 skills, TDD enforcement, RAG pipelines, and opencode-native deployment.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "install": "node scripts/install.mjs",
    "install:lite": "node scripts/install.mjs --clean --components agents,skills,instructions",
    "doctor": "node scripts/doctor.mjs",
    "init": "npx pantheon init",
    "opencode": "OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS=true opencode",
    "start": "OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS=true opencode"
  },
  "bin": {
    "pantheon-orchestrator": "./bin/pantheon-init.mjs"
  },
  "files": [
    "LICENSE",
    "scripts/install/*.mjs",
    "scripts/*.py",
    "src/plugin.ts",
    "README.md",
    "src/mcp/*.txt",
    "commands/*.md",
    "src/skills/**/*.txt",
    "src/skills/**/*.md",
    "pantheon.schema.json",
    "skills-lock.json",
    "scripts/*.sh",
    "src/agents/*.md",
    "bin/*.mjs",
    "AGENTS.md",
    "src/mcp/*.py",
    "src/instructions/*.instructions.md",
    "src/mcp/*.mjs",
    "scripts/*.mjs",
    "opencode.json",
    "src/plugins/tui/**",
    "docs/*.md",
    "scripts/*.txt",
    "src/mcp/*.sh",
    "src/routing.yml"
  ],
  "dependencies": {
    "js-yaml": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ils15/pantheon.git"
  },
  "keywords": [
    "github",
    "copilot",
    "agents",
    "skills",
    "plugin",
    "orchestration"
  ],
  "author": "ils15",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true
}